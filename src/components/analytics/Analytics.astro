---
import Ga4 from './Ga4.astro';
import Matomo from './Matomo.astro';
import { BRAND } from '../../utils/brand';

function parseJsonRecord(value) {
  if (!value) return null;
  try {
    const parsed = JSON.parse(value);
    if (!parsed || typeof parsed !== 'object' || Array.isArray(parsed)) return null;
    return Object.fromEntries(
      Object.entries(parsed).map(([key, item]) => [key, item == null ? '' : String(item)])
    );
  } catch {
    return null;
  }
}

const analyticsEnabled = import.meta.env.PUBLIC_ANALYTICS_ENABLED;
const analyticsProvider = import.meta.env.PUBLIC_ANALYTICS_PROVIDER;
const analyticsConfig = parseJsonRecord(import.meta.env.PUBLIC_ANALYTICS_CONFIG);

const normalizedProvider = (analyticsProvider || '').trim().toLowerCase();
const ga4Config = {
  measurement_id: import.meta.env.PUBLIC_GA_MEASUREMENT_ID || 'G-K6VBFJGYYK',
  tag_url: import.meta.env.PUBLIC_GA_TAG_URL || 'https://www.googletagmanager.com/gtag/js',
  send_page_view: import.meta.env.PUBLIC_GA_SEND_PAGE_VIEW || 'true',
  anonymize_ip: import.meta.env.PUBLIC_GA_ANONYMIZE_IP || 'false',
  site_key: BRAND.analytics.siteKey,
  ...(analyticsConfig?.measurement_id ? analyticsConfig : {}),
};
const explicitAnalyticsGate = analyticsEnabled ? analyticsEnabled === 'true' : true;
// GA4 is a required monitoring contract for this property, so keep it installed in prod.
const renderGa4 = import.meta.env.PROD && Boolean(ga4Config.measurement_id);
const renderMatomo =
  import.meta.env.PROD &&
  explicitAnalyticsGate &&
  normalizedProvider === 'matomo' &&
  Boolean(import.meta.env.PUBLIC_MATOMO_BASE_URL && import.meta.env.PUBLIC_MATOMO_SITE_ID);
---

{
  renderGa4 && (
    <Ga4
      measurementId={ga4Config.measurement_id}
      tagUrl={ga4Config.tag_url}
      sendPageView={ga4Config.send_page_view}
      anonymizeIp={ga4Config.anonymize_ip}
      siteKey={ga4Config.site_key || BRAND.analytics.siteKey}
      trackedLinks={BRAND.analytics.trackedLinks}
    />
  )
}
{renderMatomo && <Matomo />}
